# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# AI Provider Configuration
VITE_MISTRAL_API_KEY=your_mistral_api_key
VITE_HUGGINGFACE_API_KEY=your_huggingface_api_key

# Security Configuration
VITE_SESSION_SECRET=your-secure-session-secret-key
VITE_CACHE_ENCRYPTION_KEY=your-cache-encryption-key

# Rate Limiting & Performance
VITE_RATE_LIMIT_ENABLED=true
VITE_CACHE_ENABLED=true

# Logging Configuration
VITE_LOG_LEVEL=info
VITE_SENTRY_DSN=your_sentry_dsn_for_error_tracking

# HIPAA Compliance
VITE_HIPAA_AUDIT_ENABLED=true
VITE_DATA_RETENTION_DAYS=2555  # 7 years as required by HIPAA

# Application Configuration
VITE_APP_NAME=NelsonGPT
VITE_APP_VERSION=1.0.0
NODE_ENV=production